---
const nav = [
  { href: '#instagram', label: 'Instagram' },
  { href: '#productos', label: 'Productos' },
  { href: '#calculadora', label: 'Calculadora' },
  { href: '#servicios', label: 'Servicios' },
  { href: '#proceso', label: 'Nuestro proceso' },
  { href: '#nosotros', label: 'Nosotros' },
  { href: '#contacto', label: 'Contacto' },
];
const waPhone = '542355696327';
const base = import.meta.env.BASE_URL;
---

<header
  id="site-nav"
  class="fixed top-0 inset-x-0 z-50 transition-all duration-300"
>
  <div class="section">
    <div
      class="mt-3 flex items-center justify-between rounded-2xl border border-white/60 bg-white/75 backdrop-blur-xl shadow-[0_10px_40px_-20px_rgba(10,42,110,0.35)] pl-2 pr-3 py-2"
    >
      <a href="#inicio" aria-label="Aguas del Parque — Inicio" class="flex items-center gap-3 group">
        <img
          src={`${base}minilogo.png`}
          alt="Aguas del Parque"
          class="h-11 w-auto transition-transform group-hover:scale-[1.03]"
        />
      </a>

      <nav class="hidden lg:flex items-center gap-1">
        {
          nav.map((item) => (
            <a
              href={item.href}
              class="px-3 py-2 text-sm font-medium text-brand-ink/80 hover:text-brand-deep transition-colors relative after:absolute after:left-3 after:right-3 after:-bottom-0.5 after:h-[2px] after:rounded-full after:bg-brand-sky after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:origin-left"
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="flex items-center gap-2">
        <a
          href={`https://wa.me/${waPhone}?text=Hola!%20Quiero%20pedir%20agua`}
          target="_blank"
          rel="noopener"
          class="hidden sm:inline-flex btn-primary py-2 px-4 text-sm"
        >
          <svg viewBox="0 0 32 32" class="h-4 w-4 fill-current" aria-hidden="true"><path d="M16.003 2.667C8.638 2.667 2.67 8.635 2.667 16a13.3 13.3 0 0 0 1.78 6.667L2.667 29.333l6.844-1.747A13.3 13.3 0 0 0 16 29.333h.003C23.368 29.333 29.333 23.365 29.337 16c.002-3.561-1.385-6.91-3.903-9.429A13.25 13.25 0 0 0 16.003 2.667m0 24.444h-.002a11.06 11.06 0 0 1-5.635-1.543l-.404-.24-4.188.982 1.118-3.966-.263-.421a11.05 11.05 0 0 1-1.691-5.923c.002-6.123 4.985-11.106 11.069-11.106a11 11 0 0 1 7.831 3.245 11 11 0 0 1 3.239 7.828c-.003 6.123-4.985 11.145-11.074 11.145m6.076-8.337c-.333-.167-1.972-.972-2.277-1.083s-.527-.167-.75.167-.861 1.083-1.056 1.306-.389.25-.722.083-1.407-.518-2.68-1.654c-.99-.884-1.66-1.976-1.854-2.309s-.021-.514.146-.68c.15-.149.333-.389.5-.583.167-.195.222-.333.333-.556.111-.222.055-.417-.028-.583-.083-.167-.75-1.806-1.027-2.473-.27-.65-.546-.561-.75-.572-.194-.01-.417-.012-.639-.012s-.584.083-.889.417c-.306.333-1.167 1.139-1.167 2.778 0 1.639 1.195 3.222 1.361 3.445.167.222 2.35 3.59 5.694 5.032.796.344 1.417.549 1.902.702.798.254 1.525.218 2.099.132.641-.096 1.972-.806 2.25-1.584.278-.778.278-1.444.194-1.584-.083-.139-.305-.222-.639-.389"/></svg>
          Pedir ahora
        </a>
        <button
          id="nav-toggle"
          aria-label="Abrir menú"
          class="lg:hidden inline-flex h-10 w-10 items-center justify-center rounded-xl border border-brand-royal/15 bg-white/70"
        >
          <svg class="h-5 w-5 text-brand-deep" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round" />
          </svg>
        </button>
      </div>
    </div>

    <div
      id="mobile-menu"
      class="lg:hidden hidden mt-2 rounded-2xl border border-white/70 bg-white/90 backdrop-blur-xl p-3 shadow-deep"
    >
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="block px-3 py-2 rounded-lg text-brand-ink hover:bg-brand-foam"
          >
            {item.label}
          </a>
        ))
      }
      <a
        href={`https://wa.me/${waPhone}`}
        target="_blank"
        rel="noopener"
        class="mt-2 btn-primary w-full justify-center py-2 text-sm"
      >
        Pedir por WhatsApp
      </a>
    </div>
  </div>
</header>

<script>
  const nav = document.getElementById('site-nav');
  const onScroll = () => {
    if (!nav) return;
    if (window.scrollY > 8) nav.classList.add('is-scrolled');
    else nav.classList.remove('is-scrolled');
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => menu.classList.add('hidden')),
  );

  // ===== Scroll-spy: marca el link activo según la sección visible =====
  const navLinks = Array.from(
    document.querySelectorAll<HTMLAnchorElement>(
      '#site-nav a[href^="#"], #mobile-menu a[href^="#"]',
    ),
  ).filter((a) => a.getAttribute('href') !== '#inicio');

  const sectionIds = Array.from(
    new Set(navLinks.map((a) => (a.getAttribute('href') || '').replace('#', ''))),
  ).filter(Boolean);

  const sections = sectionIds
    .map((id) => document.getElementById(id))
    .filter((el): el is HTMLElement => !!el);

  const intersecting = new Set<HTMLElement>();
  const setActive = (id: string | null) => {
    navLinks.forEach((a) => {
      a.classList.toggle('is-active', a.getAttribute('href') === `#${id}`);
    });
  };

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) intersecting.add(e.target as HTMLElement);
        else intersecting.delete(e.target as HTMLElement);
      });
      const sorted = [...intersecting].sort(
        (a, b) => a.getBoundingClientRect().top - b.getBoundingClientRect().top,
      );
      setActive(sorted[0]?.id ?? null);
    },
    {
      rootMargin: '-30% 0px -60% 0px',
      threshold: 0,
    },
  );

  sections.forEach((s) => observer.observe(s));
</script>

<style>
  #site-nav.is-scrolled > div > div {
    box-shadow: 0 20px 60px -30px rgba(10, 42, 110, 0.45);
  }
  /* Active link state (set by scroll-spy) */
  #site-nav nav a.is-active {
    color: rgb(10 42 110); /* brand-deep */
  }
  #site-nav nav a.is-active::after {
    transform: scaleX(1);
  }
  #mobile-menu a.is-active {
    background-color: rgb(234 247 251); /* brand-foam */
    color: rgb(10 42 110);
    font-weight: 600;
  }
</style>
