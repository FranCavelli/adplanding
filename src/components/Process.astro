---
// Sección A — "De la fuente a tu casa"
// Scroll-driven: una línea vertical se va llenando con el scroll y cada paso
// aparece animado cuando entra en viewport.

const steps = [
  {
    num: '01',
    title: 'Captación',
    desc: 'Agua tomada de fuentes subterráneas habilitadas, con protocolo sanitario desde el origen.',
    icon: 'source',
  },
  {
    num: '02',
    title: 'Filtración multietapa',
    desc: 'Arena, carbón activado y microfiltración. Cada capa retiene partículas y sabores distintos.',
    icon: 'filter',
  },
  {
    num: '03',
    title: 'Análisis físico-químico',
    desc: 'Controles de laboratorio en cada lote, con certificado aprobado por organismos nacionales.',
    icon: 'lab',
  },
  {
    num: '04',
    title: 'Envasado en planta propia',
    desc: 'Sin intermediarios: los bidones se llenan y tapan en nuestra fábrica de Lincoln.',
    icon: 'fill',
  },
  {
    num: '05',
    title: 'Sellado y control final',
    desc: 'Cada bidón con tapa inviolable y verificación antes de salir a reparto.',
    icon: 'check',
  },
  {
    num: '06',
    title: 'A tu puerta',
    desc: 'Flota propia en Lincoln y la zona. Retiramos los envases retornables sin cargo.',
    icon: 'truck',
  },
];
---

<section id="proceso" class="relative py-24 lg:py-32 bg-gradient-to-b from-brand-foam/40 via-white to-white overflow-hidden">
  <div class="section">
    <div class="max-w-2xl reveal">
      <span class="chip">Nuestro proceso</span>
      <h2 class="mt-4 font-display text-4xl sm:text-5xl font-extrabold tracking-tight">
        De la fuente
        <span class="text-gradient">a tu casa.</span>
      </h2>
      <p class="mt-4 text-brand-ink/70 text-lg">
        No somos revendedores: <strong>producimos, analizamos y entregamos</strong> nosotros mismos.
        Así te garantizamos calidad en cada bidón.
      </p>
    </div>

    <div id="proceso-wrap" class="relative mt-16">
      <!-- Background rail -->
      <div aria-hidden="true" class="absolute left-8 lg:left-1/2 top-0 bottom-0 w-[3px] -translate-x-1/2 bg-brand-sky/15 rounded-full"></div>
      <!-- Fill rail (animated by scroll) -->
      <div id="proceso-fill" aria-hidden="true" class="absolute left-8 lg:left-1/2 top-0 w-[3px] -translate-x-1/2 bg-gradient-to-b from-brand-royal via-brand-sky to-brand-aqua rounded-full origin-top" style="height: 0%;"></div>

      <div class="space-y-14 lg:space-y-20">
        {
          steps.map((step, i) => (
            <div class={`proceso-step relative flex gap-6 lg:gap-16 items-center ${i % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'}`}>
              {/* Icon column — must hug the central line on both sides */}
              <div class={`lg:w-1/2 flex ${i % 2 === 0 ? 'lg:justify-end' : 'lg:justify-start'}`}>
                <div class="relative z-[1] ml-0 lg:ml-0">
                  {/* Step icon bubble */}
                  <div class="proceso-icon relative h-20 w-20 lg:h-24 lg:w-24 rounded-full bg-white border-4 border-white shadow-[0_20px_40px_-10px_rgba(10,42,110,0.35)] grid place-items-center">
                    <div class="absolute inset-1 rounded-full bg-gradient-to-br from-brand-royal via-brand-sky to-brand-aqua grid place-items-center text-white">
                      {step.icon === 'source' && (
                        <svg viewBox="0 0 40 40" class="h-10 w-10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M20 6s-7 9-7 15a7 7 0 1 0 14 0c0-6-7-15-7-15z" fill="currentColor" opacity="0.35"/>
                          <path d="M20 6s-7 9-7 15a7 7 0 1 0 14 0c0-6-7-15-7-15z"/>
                          <path d="M20 30v6M14 34h12"/>
                        </svg>
                      )}
                      {step.icon === 'filter' && (
                        <svg viewBox="0 0 40 40" class="h-10 w-10" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M8 12h24l-8 10v10l-8-4V22L8 12z"/>
                          <path d="M12 16h16M14 20h12M16 24h8" opacity="0.6"/>
                        </svg>
                      )}
                      {step.icon === 'lab' && (
                        <svg viewBox="0 0 40 40" class="h-10 w-10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M16 6v10L8 30a2 2 0 0 0 2 3h20a2 2 0 0 0 2-3l-8-14V6"/>
                          <path d="M14 6h12"/>
                          <circle cx="18" cy="26" r="1.2" fill="currentColor"/>
                          <circle cx="22" cy="22" r="1" fill="currentColor"/>
                          <circle cx="24" cy="28" r="1.4" fill="currentColor"/>
                        </svg>
                      )}
                      {step.icon === 'fill' && (
                        <svg viewBox="0 0 40 40" class="h-10 w-10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                          <path d="M14 6h12v4c0 2 4 2 4 6v18a2 2 0 0 1-2 2H12a2 2 0 0 1-2-2V16c0-4 4-4 4-6z"/>
                          <path d="M10 22h20" opacity="0.6"/>
                          <path d="M20 2v4M17 4l3-2 3 2" opacity="0.8"/>
                        </svg>
                      )}
                      {step.icon === 'check' && (
                        <svg viewBox="0 0 40 40" class="h-10 w-10" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                          <circle cx="20" cy="20" r="14" stroke-width="2"/>
                          <path d="M13 20l5 5 9-10"/>
                        </svg>
                      )}
                      {step.icon === 'truck' && (
                        <svg viewBox="0 0 40 40" class="h-10 w-10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M4 12h18v14H4z"/>
                          <path d="M22 16h6l6 6v4H22"/>
                          <circle cx="12" cy="28" r="3"/>
                          <circle cx="28" cy="28" r="3"/>
                        </svg>
                      )}
                    </div>
                    {/* Step number badge */}
                    <span class="absolute -top-2 -right-2 bg-white rounded-full px-2.5 py-1 text-xs font-display font-extrabold text-brand-deep shadow ring-1 ring-brand-sky/20">
                      {step.num}
                    </span>
                  </div>
                </div>
              </div>

              {/* Text column — alignment hugs the central line */}
              <div class={`lg:w-1/2 flex-1 pl-4 lg:pl-0 ${i % 2 === 0 ? 'lg:pl-8 lg:text-left' : 'lg:pr-8 lg:text-right'}`}>
                <h3 class="font-display text-xl sm:text-2xl font-bold text-brand-deep">{step.title}</h3>
                <p class="mt-2 text-brand-ink/70 leading-relaxed">{step.desc}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const wrap = document.getElementById('proceso-wrap');
  const fill = document.getElementById('proceso-fill');
  if (wrap && fill) {
    // Progress line fills as user scrolls through the section
    gsap.to(fill, {
      height: '100%',
      ease: 'none',
      scrollTrigger: {
        trigger: wrap,
        start: 'top center',
        end: 'bottom center',
        scrub: 0.5,
      },
    });
  }

  // Reveal each step with stagger, slight scale of icon
  document.querySelectorAll<HTMLElement>('.proceso-step').forEach((el, i) => {
    const icon = el.querySelector('.proceso-icon');
    gsap.fromTo(
      el,
      { opacity: 0, y: 40 },
      {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: { trigger: el, start: 'top 85%' },
      },
    );
    if (icon) {
      gsap.fromTo(
        icon,
        { scale: 0.6, rotate: -12 },
        {
          scale: 1,
          rotate: 0,
          duration: 0.9,
          ease: 'back.out(1.7)',
          scrollTrigger: { trigger: el, start: 'top 80%' },
        },
      );
    }
  });
</script>
