---
import DropRain from '~/components/DropRain.astro';
const waPhone = '542355696327';
const landline = '+542355450132';
---

<section id="contacto" class="relative py-24 lg:py-32">
  <div class="section">
    <div class="relative overflow-hidden rounded-3xl sm:rounded-[2.5rem] water-surface text-white p-6 sm:p-10 lg:p-14 shadow-deep">
      <!-- Rain -->
      <DropRain count={18} color="#ffffff" maxOpacity={0.35} />
      <!-- decorative drops (hidden on mobile to avoid overflow) -->
      <svg class="hidden sm:block absolute -top-10 -right-10 h-48 w-48 opacity-20 animate-float-slow" viewBox="0 0 24 24"><path d="M12 2s7 8 7 13a7 7 0 1 1-14 0c0-5 7-13 7-13z" fill="white"/></svg>
      <svg class="hidden sm:block absolute -bottom-8 left-10 h-32 w-32 opacity-15 animate-float-slow" style="animation-delay: -3s;" viewBox="0 0 24 24"><path d="M12 2s7 8 7 13a7 7 0 1 1-14 0c0-5 7-13 7-13z" fill="white"/></svg>

      <div class="relative grid lg:grid-cols-2 gap-10 items-center">
        <div class="reveal">
          <span class="inline-flex items-center gap-2 rounded-full bg-white/15 border border-white/30 px-3 py-1 text-xs font-medium">
            <span class="h-1.5 w-1.5 rounded-full bg-brand-mint"></span>
            Disponibles ahora
          </span>
          <h2 class="mt-4 font-display text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight">
            Pedí tu agua
            <span class="block text-brand-mint">en menos de 1 minuto.</span>
          </h2>
          <p class="mt-4 text-white/80 text-lg max-w-lg">
            Escribinos por WhatsApp y te confirmamos la entrega para hoy o mañana. También podés llamarnos o visitarnos en la fábrica.
          </p>

          <div class="mt-8 flex flex-col sm:flex-row sm:flex-wrap gap-3">
            <a href={`https://wa.me/${waPhone}?text=Hola!%20Quiero%20hacer%20un%20pedido`} target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 rounded-full bg-white text-brand-deep px-5 sm:px-6 py-3 font-semibold shadow-xl hover:scale-[1.02] transition-transform">
              <svg viewBox="0 0 32 32" class="h-5 w-5 fill-current shrink-0"><path d="M16.003 2.667C8.638 2.667 2.67 8.635 2.667 16a13.3 13.3 0 0 0 1.78 6.667L2.667 29.333l6.844-1.747A13.3 13.3 0 0 0 16 29.333h.003C23.368 29.333 29.333 23.365 29.337 16c.002-3.561-1.385-6.91-3.903-9.429A13.25 13.25 0 0 0 16.003 2.667m0 24.444h-.002a11.06 11.06 0 0 1-5.635-1.543l-.404-.24-4.188.982 1.118-3.966-.263-.421a11.05 11.05 0 0 1-1.691-5.923c.002-6.123 4.985-11.106 11.069-11.106a11 11 0 0 1 7.831 3.245 11 11 0 0 1 3.239 7.828c-.003 6.123-4.985 11.145-11.074 11.145m6.076-8.337c-.333-.167-1.972-.972-2.277-1.083s-.527-.167-.75.167-.861 1.083-1.056 1.306-.389.25-.722.083-1.407-.518-2.68-1.654c-.99-.884-1.66-1.976-1.854-2.309s-.021-.514.146-.68c.15-.149.333-.389.5-.583.167-.195.222-.333.333-.556.111-.222.055-.417-.028-.583-.083-.167-.75-1.806-1.027-2.473-.27-.65-.546-.561-.75-.572-.194-.01-.417-.012-.639-.012s-.584.083-.889.417c-.306.333-1.167 1.139-1.167 2.778 0 1.639 1.195 3.222 1.361 3.445.167.222 2.35 3.59 5.694 5.032.796.344 1.417.549 1.902.702.798.254 1.525.218 2.099.132.641-.096 1.972-.806 2.25-1.584.278-.778.278-1.444.194-1.584-.083-.139-.305-.222-.639-.389"/></svg>
              <span class="whitespace-nowrap">WhatsApp <span class="hidden sm:inline">· 2355 69-6327</span></span>
            </a>
            <a href={`tel:${landline}`} class="inline-flex items-center justify-center gap-2 rounded-full border border-white/40 text-white px-5 sm:px-6 py-3 font-semibold hover:bg-white/10 transition-colors">
              <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.6a2 2 0 0 1-.5 2.1L8 9.5a16 16 0 0 0 6 6l1.1-1.1a2 2 0 0 1 2.1-.5c.8.3 1.7.5 2.6.6A2 2 0 0 1 22 16.9z" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span class="whitespace-nowrap">2355 45-0132</span>
            </a>
          </div>

          <div class="mt-10 grid sm:grid-cols-2 gap-4">
            <div class="rounded-2xl bg-white/10 border border-white/15 p-4">
              <div class="flex items-center gap-2 text-xs text-white/70 uppercase tracking-widest">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
                Horario
              </div>
              <div class="mt-1 font-display font-bold">Lun a Sáb · 8 a 19 hs</div>
            </div>
            <div class="rounded-2xl bg-white/10 border border-white/15 p-4">
              <div class="flex items-center gap-2 text-xs text-white/70 uppercase tracking-widest">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 1 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                Dirección
              </div>
              <div class="mt-1 font-display font-bold">Catamarca 42<br/>Lincoln, Buenos Aires</div>
            </div>
          </div>
        </div>

        <form
          class="reveal card rounded-3xl p-6 text-brand-ink"
          id="contact-form"
          onsubmit="return false;"
        >
          <h3 class="font-display font-bold text-brand-deep text-lg">Contanos qué necesitás</h3>
          <p class="text-sm text-brand-ink/60 mt-1">Te contactamos en minutos por WhatsApp.</p>

          <div class="mt-5 grid gap-3">
            <label class="grid gap-1">
              <span class="text-xs font-medium text-brand-ink/70">Nombre</span>
              <input name="nombre" type="text" required class="rounded-xl border border-brand-sky/30 bg-white px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-sky/60" placeholder="Tu nombre" />
            </label>
            <label class="grid gap-1">
              <span class="text-xs font-medium text-brand-ink/70">Teléfono / WhatsApp</span>
              <input name="telefono" type="tel" required class="rounded-xl border border-brand-sky/30 bg-white px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-sky/60" placeholder="Ej: 2355 555555" />
            </label>
            <label class="grid gap-1">
              <span class="text-xs font-medium text-brand-ink/70">¿Qué querés pedir?</span>
              <select name="producto" class="rounded-xl border border-brand-sky/30 bg-white px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-sky/60">
                <option>Bidón 20L</option>
                <option>Bidón 12L</option>
                <option>Bidón 10L</option>
                <option>Bidón 5L</option>
                <option>Soda</option>
                <option>Dispenser frío/calor</option>
                <option>Otro</option>
              </select>
            </label>
            <label class="grid gap-1">
              <span class="text-xs font-medium text-brand-ink/70">Mensaje</span>
              <textarea name="mensaje" rows="3" class="rounded-xl border border-brand-sky/30 bg-white px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-sky/60" placeholder="Dirección, cantidad, horario…"></textarea>
            </label>
            <button type="submit" class="btn-primary justify-center mt-2">
              Enviar por WhatsApp
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2 11 13" stroke-linecap="round" stroke-linejoin="round"/><path d="M22 2 15 22l-4-9-9-4Z" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ waPhone }}>
  // Envía el formulario por WhatsApp: arma el mensaje y abre wa.me
  const form = document.getElementById('contact-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const f = e.target;
    const nombre = f.nombre.value.trim();
    const telefono = f.telefono.value.trim();
    const producto = f.producto.value;
    const mensaje = f.mensaje.value.trim();
    const text =
`Hola! Soy ${nombre || '(sin nombre)'}.
Producto: ${producto}
Mensaje: ${mensaje || '(sin mensaje)'}
Tel: ${telefono}`;
    window.open(`https://wa.me/${waPhone}?text=${encodeURIComponent(text)}`, '_blank');
  });
</script>
